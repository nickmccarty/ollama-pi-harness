<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <style>
    :root {
      --bg: #0d1117;
      --surface: #161b22;
      --border: #30363d;
      --text: #e6edf3;
      --text-muted: #7d8590;
      --text-node: #111;
      --accent: #58a6ff;
      --edge: #484f58;
      --edge-label: #8b949e;
      --tooltip-bg: #1c2128;
      --tooltip-border: #444c56;
      --btn-bg: #21262d;
      --btn-hover: #30363d;
      --btn-text: #c9d1d9;
      --slider-track: #30363d;
      --highlight: #f78166;
      --shadow: rgba(0,0,0,0.4);
    }
    .light {
      --bg: #f6f8fa;
      --surface: #ffffff;
      --border: #d0d7de;
      --text: #1f2328;
      --text-muted: #656d76;
      --text-node: #111;
      --accent: #0969da;
      --edge: #b1bac4;
      --edge-label: #57606a;
      --tooltip-bg: #ffffff;
      --tooltip-border: #d0d7de;
      --btn-bg: #f6f8fa;
      --btn-hover: #eaeef2;
      --btn-text: #1f2328;
      --slider-track: #d0d7de;
      --highlight: #cf222e;
      --shadow: rgba(0,0,0,0.1);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; overflow: hidden; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; }
    #app {
      display: flex;
      flex-direction: column;
      height: 100vh;
      background: var(--bg);
      color: var(--text);
      transition: background 0.2s, color 0.2s;
    }
    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 18px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      gap: 12px;
      flex-shrink: 0;
      flex-wrap: wrap;
    }
    .header-left h1 {
      font-size: 15px;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: var(--text);
    }
    .header-left .meta {
      font-size: 11px;
      color: var(--text-muted);
      margin-top: 1px;
      display: block;
    }
    .controls {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }
    button {
      padding: 5px 11px;
      background: var(--btn-bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--btn-text);
      font-size: 12px;
      cursor: pointer;
      transition: background 0.15s;
      white-space: nowrap;
    }
    button:hover { background: var(--btn-hover); }
    .slider-group {
      display: flex;
      align-items: center;
      gap: 5px;
      font-size: 11px;
      color: var(--text-muted);
    }
    .slider-group input[type=range] {
      width: 80px;
      accent-color: var(--accent);
      cursor: pointer;
    }
    #graph-container {
      flex: 1;
      overflow: hidden;
      position: relative;
    }
    #graph {
      width: 100%;
      height: 100%;
    }
    /* Nodes */
    .node circle {
      stroke-width: 1.5px;
      stroke: rgba(0,0,0,0.15);
      cursor: grab;
      transition: stroke-width 0.15s;
    }
    .node circle:active { cursor: grabbing; }
    .node text {
      font-size: 11px;
      font-weight: 500;
      fill: var(--text-node);
      pointer-events: none;
      user-select: none;
      dominant-baseline: central;
      text-anchor: middle;
    }
    .node.highlighted circle { stroke: var(--highlight); stroke-width: 2.5px; }
    .node.dimmed { opacity: 0.25; }
    /* Edges */
    .link {
      stroke: var(--edge);
      stroke-width: 1.5px;
      fill: none;
      transition: stroke 0.15s;
    }
    .link.highlighted { stroke: var(--highlight); stroke-width: 2px; }
    .link.dimmed { opacity: 0.1; }
    .link-label {
      font-size: 10px;
      fill: var(--edge-label);
      pointer-events: none;
      user-select: none;
    }
    .link-label.dimmed { opacity: 0.1; }
    /* Tooltip */
    #tooltip {
      position: fixed;
      background: var(--tooltip-bg);
      border: 1px solid var(--tooltip-border);
      border-radius: 8px;
      padding: 8px 12px;
      font-size: 12px;
      color: var(--text);
      pointer-events: none;
      display: none;
      box-shadow: 0 4px 16px var(--shadow);
      max-width: 240px;
      line-height: 1.5;
      z-index: 100;
    }
    #tooltip .tip-label { font-weight: 600; margin-bottom: 2px; }
    #tooltip .tip-connections { font-size: 11px; color: var(--text-muted); }
    footer {
      padding: 6px 18px;
      background: var(--surface);
      border-top: 1px solid var(--border);
      font-size: 11px;
      color: var(--text-muted);
      flex-shrink: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    /* Legend */
    #legend {
      position: absolute;
      bottom: 12px;
      right: 14px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 8px 12px;
      font-size: 11px;
      color: var(--text-muted);
      line-height: 1.8;
      box-shadow: 0 2px 8px var(--shadow);
    }
    #legend div { display: flex; align-items: center; gap: 6px; }
    #legend .swatch {
      width: 10px; height: 10px; border-radius: 50%;
      background: var(--accent); flex-shrink: 0;
    }
    #legend .line-swatch {
      width: 16px; height: 2px; background: var(--edge); flex-shrink: 0;
    }
  </style>
</head>
<body>
<div id="app" class="light">
  <header>
    <div class="header-left">
      <h1>{{ title }}</h1>
      <span class="meta">{{ node_count }} nodes &middot; {{ edge_count }} edges &middot; {{ model }}</span>
    </div>
    <div class="controls">
      <button id="btn-theme">&#9790; Dark</button>
      <button id="btn-reset">&#8635; Reset</button>
      <button id="btn-export">&#8595; SVG</button>
      <div class="slider-group">
        <span>Distance</span>
        <input type="range" id="slider-distance" min="60" max="280" value="130">
      </div>
      <div class="slider-group">
        <span>Repulsion</span>
        <input type="range" id="slider-charge" min="-700" max="-80" value="-280">
      </div>
    </div>
  </header>

  <div id="graph-container">
    <svg id="graph"></svg>
    <div id="legend">
      <div><span class="swatch"></span> Node (drag to reposition)</div>
      <div><span class="line-swatch"></span> Directed relationship</div>
      <div style="color:var(--text-muted);margin-top:2px">Click node to highlight connections</div>
      <div style="color:var(--text-muted)">Scroll to zoom &middot; drag canvas to pan</div>
    </div>
  </div>

  <div id="tooltip"></div>

  <footer>
    Generated {{ generated_at }} &middot; {{ article_snippet }}
  </footer>
</div>

<script>
  const GRAPH_DATA = {{ graph_json | safe }};
</script>
<script src="https://d3js.org/d3.v7.min.js"></script>
<script>
(function () {
  // ── Config ──────────────────────────────────────────────────────────────────
  const NODE_RADIUS = 22;
  const ARROW_SIZE  = 8;

  // ── State ───────────────────────────────────────────────────────────────────
  let linkDistance = +document.getElementById('slider-distance').value;
  let chargeStrength = +document.getElementById('slider-charge').value;
  let selectedNode = null;
  let isDark = false;

  const app  = document.getElementById('app');
  const tip  = document.getElementById('tooltip');

  // ── SVG setup ───────────────────────────────────────────────────────────────
  const container = document.getElementById('graph-container');
  const svg = d3.select('#graph');

  function getSize() {
    return { w: container.clientWidth, h: container.clientHeight };
  }

  const g = svg.append('g').attr('class', 'root');

  // Zoom
  const zoom = d3.zoom()
    .scaleExtent([0.2, 4])
    .on('zoom', (event) => g.attr('transform', event.transform));
  svg.call(zoom).on('dblclick.zoom', null);

  // ── Arrow marker defs ────────────────────────────────────────────────────────
  const defs = svg.append('defs');

  function addMarker(id, color) {
    defs.append('marker')
      .attr('id', id)
      .attr('viewBox', '0 -4 8 8')
      .attr('refX', 8)
      .attr('refY', 0)
      .attr('markerWidth', ARROW_SIZE)
      .attr('markerHeight', ARROW_SIZE)
      .attr('orient', 'auto')
      .append('path')
        .attr('d', 'M0,-4L8,0L0,4')
        .attr('fill', color);
  }

  addMarker('arrow-default', '#484f58');
  addMarker('arrow-highlight', '#f78166');
  addMarker('arrow-light-default', '#b1bac4');
  addMarker('arrow-light-highlight', '#cf222e');

  function currentMarker(isHighlight) {
    const theme = isDark ? '' : 'light-';
    return `url(#arrow-${theme}${isHighlight ? 'highlight' : 'default'})`;
  }

  // ── Data prep ────────────────────────────────────────────────────────────────
  const nodeMap = {};
  GRAPH_DATA.nodes.forEach(n => { nodeMap[n.id] = n; });

  const nodes = GRAPH_DATA.nodes.map(n => ({ ...n }));
  const links = GRAPH_DATA.edges.map(e => ({
    source: e.src,
    target: e.dst,
    label:  e.label,
  }));

  // Adjacency for click-highlight
  function getNeighbors(nodeId) {
    const neighborIds = new Set();
    const connectedLinks = [];
    links.forEach(l => {
      const sid = typeof l.source === 'object' ? l.source.id : l.source;
      const tid = typeof l.target === 'object' ? l.target.id : l.target;
      if (sid === nodeId || tid === nodeId) {
        neighborIds.add(sid);
        neighborIds.add(tid);
        connectedLinks.push(l);
      }
    });
    return { neighborIds, connectedLinks };
  }

  // ── Simulation ───────────────────────────────────────────────────────────────
  let { w, h } = getSize();

  const simulation = d3.forceSimulation(nodes)
    .force('link', d3.forceLink(links)
      .id(d => d.id)
      .distance(() => linkDistance)
      .strength(0.5))
    .force('charge', d3.forceManyBody().strength(() => chargeStrength))
    .force('center', d3.forceCenter(w / 2, h / 2))
    .force('collide', d3.forceCollide(NODE_RADIUS + 14))
    .on('tick', ticked);

  // ── Render elements ──────────────────────────────────────────────────────────
  // Links (paths for curves)
  const linkGroup = g.append('g').attr('class', 'links');
  let linkEl = linkGroup.selectAll('path')
    .data(links).enter()
    .append('path')
    .attr('class', 'link')
    .attr('marker-end', () => currentMarker(false));

  // Link labels
  const linkLabelGroup = g.append('g').attr('class', 'link-labels');
  let linkLabelEl = linkLabelGroup.selectAll('text')
    .data(links).enter()
    .append('text')
    .attr('class', 'link-label')
    .text(d => d.label);

  // Nodes
  const nodeGroup = g.append('g').attr('class', 'nodes');
  let nodeEl = nodeGroup.selectAll('g.node')
    .data(nodes).enter()
    .append('g')
    .attr('class', 'node')
    .call(d3.drag()
      .on('start', dragStart)
      .on('drag',  dragged)
      .on('end',   dragEnd))
    .on('mouseover', onNodeHover)
    .on('mousemove', onMouseMove)
    .on('mouseout',  onNodeOut)
    .on('click', onNodeClick);

  nodeEl.append('circle')
    .attr('r', NODE_RADIUS)
    .attr('fill', d => d.color || '#a0c4ff');

  nodeEl.append('text')
    .text(d => d.label)
    .each(function(d) {
      // Wrap long labels
      const el = d3.select(this);
      const words = d.label.split(' ');
      if (words.length > 3) {
        const mid = Math.ceil(words.length / 2);
        el.text('');
        el.append('tspan')
          .attr('x', 0).attr('dy', '-0.6em')
          .text(words.slice(0, mid).join(' '));
        el.append('tspan')
          .attr('x', 0).attr('dy', '1.2em')
          .text(words.slice(mid).join(' '));
      }
    });

  // ── Tick function ─────────────────────────────────────────────────────────────
  function linkPath(d) {
    const sx = d.source.x, sy = d.source.y;
    const tx = d.target.x, ty = d.target.y;
    const dx = tx - sx, dy = ty - sy;
    const dist = Math.sqrt(dx * dx + dy * dy) || 1;

    // Start at node edge
    const x1 = sx + (dx / dist) * NODE_RADIUS;
    const y1 = sy + (dy / dist) * NODE_RADIUS;
    // End before arrowhead (account for marker refX + node radius)
    const arrowOffset = NODE_RADIUS + ARROW_SIZE + 2;
    const x2 = tx - (dx / dist) * arrowOffset;
    const y2 = ty - (dy / dist) * arrowOffset;

    // Slight quadratic curve (perpendicular offset = 15% of length)
    const cx = (sx + tx) / 2 - (dy / dist) * (dist * 0.10);
    const cy = (sy + ty) / 2 + (dx / dist) * (dist * 0.10);

    return `M${x1},${y1} Q${cx},${cy} ${x2},${y2}`;
  }

  function labelPos(d) {
    const sx = d.source.x, sy = d.source.y;
    const tx = d.target.x, ty = d.target.y;
    const dx = tx - sx, dy = ty - sy;
    const dist = Math.sqrt(dx * dx + dy * dy) || 1;
    // Perpendicular offset
    const ox = -(dy / dist) * 14;
    const oy =  (dx / dist) * 14;
    return {
      x: (sx + tx) / 2 + ox,
      y: (sy + ty) / 2 + oy,
    };
  }

  function ticked() {
    linkEl.attr('d', linkPath);

    linkLabelEl.each(function(d) {
      const pos = labelPos(d);
      d3.select(this).attr('x', pos.x).attr('y', pos.y);
    });

    nodeEl.attr('transform', d => `translate(${d.x},${d.y})`);
  }

  // ── Drag ─────────────────────────────────────────────────────────────────────
  function dragStart(event, d) {
    if (!event.active) simulation.alphaTarget(0.3).restart();
    d.fx = d.x; d.fy = d.y;
  }
  function dragged(event, d) { d.fx = event.x; d.fy = event.y; }
  function dragEnd(event, d) {
    if (!event.active) simulation.alphaTarget(0);
    d.fx = null; d.fy = null;
  }

  // ── Tooltip ───────────────────────────────────────────────────────────────────
  function onNodeHover(event, d) {
    const { neighborIds } = getNeighbors(d.id);
    const degree = neighborIds.size - 1;
    tip.style.display = 'block';
    tip.innerHTML = `<div class="tip-label">${d.label}</div>
      <div class="tip-connections">${degree} connection${degree !== 1 ? 's' : ''}</div>`;
  }
  function onMouseMove(event) {
    tip.style.left  = (event.clientX + 14) + 'px';
    tip.style.top   = (event.clientY - 28) + 'px';
  }
  function onNodeOut() { tip.style.display = 'none'; }

  // ── Click highlight ───────────────────────────────────────────────────────────
  function onNodeClick(event, d) {
    event.stopPropagation();
    if (selectedNode === d.id) {
      clearHighlight();
      selectedNode = null;
      return;
    }
    selectedNode = d.id;
    const { neighborIds, connectedLinks } = getNeighbors(d.id);

    nodeEl.classed('highlighted', n => neighborIds.has(n.id));
    nodeEl.classed('dimmed', n => !neighborIds.has(n.id));

    linkEl
      .classed('highlighted', l => connectedLinks.includes(l))
      .classed('dimmed', l => !connectedLinks.includes(l))
      .attr('marker-end', l => currentMarker(connectedLinks.includes(l)));

    linkLabelEl.classed('dimmed', l => !connectedLinks.includes(l));
  }

  svg.on('click', () => {
    clearHighlight();
    selectedNode = null;
  });

  function clearHighlight() {
    nodeEl.classed('highlighted', false).classed('dimmed', false);
    linkEl.classed('highlighted', false).classed('dimmed', false)
      .attr('marker-end', () => currentMarker(false));
    linkLabelEl.classed('dimmed', false);
  }

  // ── Controls ──────────────────────────────────────────────────────────────────
  document.getElementById('btn-theme').addEventListener('click', () => {
    isDark = !isDark;
    app.classList.toggle('light', !isDark);
    document.getElementById('btn-theme').textContent = isDark ? '\u2600 Light' : '\u263d Dark';
    // Update markers on existing elements
    linkEl.attr('marker-end', () => currentMarker(false));
    clearHighlight();
  });

  document.getElementById('btn-reset').addEventListener('click', () => {
    const { w, h } = getSize();
    svg.transition().duration(600)
      .call(zoom.transform, d3.zoomIdentity.translate(0, 0).scale(1));
    simulation.alpha(0.4).restart();
  });

  document.getElementById('btn-export').addEventListener('click', () => {
    const svgEl = document.getElementById('graph');
    const clone = svgEl.cloneNode(true);
    clone.removeAttribute('style');
    clone.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
    // Inline background color
    clone.style.background = isDark ? '#0d1117' : '#f6f8fa';
    const blob = new Blob([clone.outerHTML], { type: 'image/svg+xml' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = 'knowledge-graph.svg'; a.click();
    URL.revokeObjectURL(url);
  });

  document.getElementById('slider-distance').addEventListener('input', function() {
    linkDistance = +this.value;
    simulation.force('link').distance(() => linkDistance);
    simulation.alpha(0.4).restart();
  });

  document.getElementById('slider-charge').addEventListener('input', function() {
    chargeStrength = +this.value;
    simulation.force('charge').strength(() => chargeStrength);
    simulation.alpha(0.4).restart();
  });

  // ── Resize ────────────────────────────────────────────────────────────────────
  window.addEventListener('resize', () => {
    const { w, h } = getSize();
    simulation.force('center', d3.forceCenter(w / 2, h / 2));
    simulation.alpha(0.1).restart();
  });

  // Initial zoom-to-fit after simulation settles
  simulation.on('end', () => {
    const { w, h } = getSize();
    const bounds = g.node().getBBox();
    const pad = 60;
    const scale = Math.min(
      (w - pad * 2) / bounds.width,
      (h - pad * 2) / bounds.height,
      1.2,
    );
    const tx = w / 2 - scale * (bounds.x + bounds.width  / 2);
    const ty = h / 2 - scale * (bounds.y + bounds.height / 2);
    svg.transition().duration(800)
      .call(zoom.transform, d3.zoomIdentity.translate(tx, ty).scale(scale))
      .on('end', () => {
        // Signal that the graph is fully rendered and positioned — used by Playwright
        document.body.setAttribute('data-kg-ready', 'true');
      });
  });
})();
</script>
</body>
</html>
